# TapPrint - copy to .env on the print-server laptop.

PORT=8080
HOST=0.0.0.0
SESSION_SECRET=change-this-to-a-long-random-string
OPERATOR_PIN=1234

# Gmail API (OAuth2 refresh token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

POLL_INTERVAL_SECONDS=45
MAX_PDF_MB=25

JOBS_DIR=./jobs
DATABASE_PATH=./data/tapprint.db

SUMATRA_PATH=C:\\Program Files\\SumatraPDF\\SumatraPDF.exe

PRINTER_BW=ReceiptPrinter_BW
PRINTER_COLOR=ReceiptPrinter_Color
